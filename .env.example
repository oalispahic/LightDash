# Copy this file to .env and fill in your values
# Never commit .env to version control

# Backend
NODE_ENV=production
PORT=3000

# Server display name (shown in login screen, sidebar, and title)
SERVER_NAME=MyServer

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-secret-key-here-generate-a-random-32-byte-hex-string

# Telegram Integration (optional - leave blank if not using)
# Get these from: https://core.telegram.org/bots
TELEGRAM_API_KEY=
TELEGRAM_CHAT_ID=

# Shared secret between backend and marex-sysd (systems agent).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYSD_TOKEN=
